{
	"manifest_version": 2,
	"name": "omfj | Start",
	"version": "1.0.2",
	"description": "Custom new tab page",
	"browser_specific_settings": {
		"gecko": {
			"id": "start@omfj.no",
			"data_collection_permissions": {
				"required": [
					"none"
				],
				"optional": []
			}
		}
	},
	"chrome_url_overrides": {
		"newtab": "index.html"
	},
	"icons": {
		"16": "favicon-16x16.png",
		"32": "favicon-32x32.png",
		"48": "favicon-32x32.png",
		"128": "android-chrome-192x192.png"
	}
}
